{
  "extends": ["airbnb-base", "prettier"],
  "parser": "babel-eslint",
  "rules": {
    "semi": ["error", "never"],
    "no-console": "off",
    "no-unused-expressions": "off",
    "func-names": "off",
    "camelcase": "off",
    "no-restricted-syntax": "off",
    "import/prefer-default-export": "off"
  },
  "globals": {
    "Modernizr": true
  },
  "env": {
    "browser": true,
    "node": true,
    "jest": true
  }
}
