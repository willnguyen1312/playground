{
  "extends": "airbnb-base",
  "parser": "babel-eslint",
  "rules": {
    "semi": ["error", "never"],
    "no-console": "off",
    "no-unused-expressions": "off",
    "func-names": "off",
    "camelcase": "off",
    "no-restricted-syntax": "off"
  },
  "globals": {
    "Modernizr": true
  },
  "env": {
    "browser": true
  }
}
